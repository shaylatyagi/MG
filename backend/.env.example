# ─── MobilityGrid Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in values.
# .env is gitignored — NEVER commit real secrets.

# ── Database ─────────────────────────────────────────────────────────────────
# Current: Neon PostgreSQL (free tier)
# AWS migration: Replace with RDS endpoint — no code change needed
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_min_32_chars
ADMIN_SECRET_KEY=mg_admin_2026_secret
ADMIN_PHONE=9999999999

# ── OTP / Email ───────────────────────────────────────────────────────────────
# Admin OTP sent via Brevo SMTP (free up to 300 emails/day — brevo.com)
BREVO_USER=your_brevo_login_email
BREVO_PASS=your_brevo_smtp_password
ADMIN_EMAIL=papa_email@gmail.com   # OTP for admin login is sent here

# ── Payment Gateway ───────────────────────────────────────────────────────────
PAYYANTRA_API_KEY=your_payyantra_api_key
PAYYANTRA_API_URL=https://api.payyantra.com
PAYYANTRA_WEBHOOK_SECRET=your_webhook_hmac_secret

# ── AWS — Add when papa configures AWS (no code change needed) ───────────────
# S3 — KYC document storage
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=mobilitygrid-docs

# Redis / ElastiCache — OTP rate limiting (replaces in-memory Map)
REDIS_URL=redis://localhost:6379

# SQS — webhook queue (decouples PayYantra callbacks from DB writes)
SQS_WEBHOOK_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/123456789/mg-webhook-queue

# CloudFront — CDN base URL for KYC document pre-signed URL generation
CLOUDFRONT_DOMAIN=https://dxxxxxxxx.cloudfront.net

# ── App URLs (used in PayYantra callbacks, payment.service.js) ───────────────
APP_BASE_URL=https://mobilitygrid.in
API_BASE_URL=https://mg-qw5s.onrender.com

# ── DB Pool (optional tuning) ────────────────────────────────────────────────
# Neon free tier: max 5 connections. Default 4 leaves headroom.
DB_POOL_MAX=4

# ── AI / Vision (free tier) ──────────────────────────────────────────────────
# Gemini 1.5 Flash — free from aistudio.google.com (no credit card needed)
# Used for: KYC document OCR + vehicle damage comparison
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# ── Business Rules (configurable) ────────────────────────────────────────────
# Set to true to block vehicle assignment if driver KYC not VERIFIED (BR-03)
KYC_REQUIRED_FOR_ASSIGNMENT=false

# ── App Config ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# Dev only — set to true for OTP bypass (000000 works), NEVER in prod
DEV_BYPASS_OTP=true
