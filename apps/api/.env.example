# apps/api/.env.example — copy to .env for local dev
NODE_ENV=development
PORT=5000

# Database (Neon / local PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_32

# Admin
ADMIN_SECRET_KEY=mg_admin_2026_secret
ADMIN_PHONE=9876543210

# Dev only — allows OTP 000000 for testing
DEV_BYPASS_OTP=true

# PayYantra
PAYYANTRA_CLIENT_ID=
PAYYANTRA_CLIENT_SECRET=
PAYYANTRA_WEBHOOK_SECRET=
PAYYANTRA_BASE_URL=https://payin-api.payyantra.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX

# AWS (production only)
S3_BUCKET=mobilitygrid-docs
REDIS_URL=redis://localhost:6379
SQS_NOTIFICATION_URL=
SQS_AUDIT_URL=
SQS_WEBHOOK_URL=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173
