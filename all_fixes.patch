+// GET /api/admin/login-logs — login location log for all users
+// Query: ?limit=100&role=DRIVER|OWNER|ADMIN&search=<name/phone>
+router.get('/login-logs', async (req, res) => {
+  try {
+    const limit  = Math.min(parseInt(req.query.limit || 100), 500);
+    const role   = (req.query.role || '').toUpperCase();
+    const search = (req.query.search || '').trim();
+
+    let where  = [];
+    let params = [];
+    let pIdx   = 1;
+
+    if (role && ['DRIVER','OWNER','ADMIN'].includes(role)) {
+      where.push(`user_role = $${pIdx++}`);
+      params.push(role);
+    }
+    if (search) {
+      where.push(`(full_name ILIKE $${pIdx} OR phone_number ILIKE $${pIdx})`);
+      params.push(`%${search}%`);
+      pIdx++;
+    }
+
+    const whereClause = where.length ? 'WHERE ' + where.join(' AND ') : '';
+
+    const result = await pool.query(
+      `SELECT id, user_id, user_role, full_name, phone_number,
+              latitude, longitude, ip_address, device_info, logged_in_at
+       FROM public.login_location_log
+       ${whereClause}
+       ORDER BY logged_in_at DESC
+       LIMIT $${pIdx}`,
+      [...params, limit]
+    );
+
+    res.json({ success: true, data: result.rows, total: result.rows.length });
+  } catch (err) {
+    console.error('admin/login-logs:', err);
+    res.status(500).json({ success: false, error: err.message });
+  }
+});
