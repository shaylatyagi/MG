{
  "id": "/login?role=driver",
  "short_name": "MG Driver",
  "name": "MobilityGrid - Driver App",
  "description": "Track trips, earnings, and manage your EV vehicle with MobilityGrid",
  "icons": [
    {
      "src": "icon-driver-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-driver-192-maskable.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icon-driver-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icon-driver-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "start_url": "/login?role=driver",
  "display": "standalone",
  "orientation": "portrait",
  "theme_color": "#16a34a",
  "background_color": "#ffffff",
  "scope": "/",
  "lang": "en",
  "dir": "ltr",
  "categories": [
    "business",
    "productivity"
  ],
  "screenshots": [
    {
      "src": "screenshot-driver.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "MobilityGrid Driver Dashboard"
    }
  ],
  "shortcuts": [
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "View your dashboard",
      "url": "/driver/dashboard",
      "icons": [
        {
          "src": "icon-driver-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Earnings",
      "short_name": "Earnings",
      "description": "Check your earnings",
      "url": "/driver/dashboard?tab=earnings",
      "icons": [
        {
          "src": "icon-driver-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "SOS",
      "short_name": "SOS",
      "description": "Emergency SOS alert",
      "url": "/driver/dashboard?tab=sos",
      "icons": [
        {
          "src": "icon-driver-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/driver/dashboard",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "handle_links": "preferred",
  "display_override": [
    "window-controls-overlay",
    "tabbed",
    "standalone",
    "minimal-ui",
    "browser"
  ],
  "file_handlers": [
    {
      "action": "/driver/dashboard",
      "accept": {
        "image/jpeg": [
          ".jpg",
          ".jpeg"
        ],
        "image/png": [
          ".png"
        ],
        "application/pdf": [
          ".pdf"
        ]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+mgdriver",
      "url": "/driver/dashboard?q=%s"
    }
  ],
  "widgets": [
    {
      "name": "Driver Status",
      "tag": "driver-status",
      "ms_ac_template": "/widget/driver-ac-template.json",
      "data": "/api/widget/driver-status",
      "description": "Today's trips and earnings",
      "screenshots": [
        {
          "src": "screenshot-driver.png",
          "sizes": "1080x1920",
          "label": "Driver Status"
        }
      ],
      "icons": [
        {
          "src": "icon-driver-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 1800
    }
  ],
  "note_taking": {
    "new_note_url": "/driver/dashboard?action=note"
  },
  "tab_strip": {
    "home_tab_icon": {
      "src": "icon-driver-192.png",
      "sizes": "192x192"
    }
  },
  "prefer_related_applications": false,
  "related_applications": [],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "scope_extensions": [
    {
      "origin": "https://mobilitygrid.in"
    },
    {
      "origin": "https://www.mobilitygrid.in"
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}